    <title>Transport Allowance App | APSS</title>
    <style>
        /* CSS to remove margins and make iframe take 100% of the screen */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100vh; /* Viewport height for full screen */
            overflow: hidden; /* Hide scrollbars on the main page */
            background-color: #f4f6f9; /* Matches app background */
            font-family: Arial, sans-serif;
        }

        /* Iframe styling for seamless embedding */
        .app-iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none; /* Removes the border around the iframe */
        }
    </style>
</head>
<body>

    <iframe 
        class="app-iframe" 
        src="https://script.google.com/macros/s/AKfycbzZQamqImhT8crdGRWewKcxRa5cl1WlIxovkH9v80LSpeDbKGfbEV-WgMSHur1NC5fl/exec" 
